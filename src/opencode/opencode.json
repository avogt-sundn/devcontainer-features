{
  "$schema": "https://opencode.ai/config.json",
  "model": "${MODEL}",
  "provider": {
    "lmstudio": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LM Studio",
      "options": {
        "baseURL": "${LMSTUDIO}/v1"
      },
      "models": {
        "qwen3.6-35b-a3b": {
          "name": "Qwen3.6-35b-A3B"
        }
      }
    },
    "mlx": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "MLX (local Apple Silicon)",
      "options": {
        "baseURL": "${MLX_SERVER}/v1"
      },
      "models": {
        "gemma-4-26b-a4b-it-mlx": {
          "name": "gemma-4-26b-a4b-it-mlx"
        },
        "qwen3.6-27b-mlx": {
          "name": "qwen3.6-27b-mlx"
        },
        "google/gemma-4-26b-a4b-qat": {
          "name": "google/gemma-4-26b-a4b-qat"
        },
        "google/gemma-4-e4b": {
          "name": "google/gemma-4-e4b"
        }
      }
    }
  }
}
